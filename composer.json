{
    "name": "daniel-km/omeka-s-module-dynamic-item-sets",
    "type": "omeka-s-module",
    "description": "Module for Omeka S: Allow to include/exclude items to item sets automatically with a standard query.",
    "keywords": [
        "Omeka S",
        "Omeka S module",
        "resource edition",
        "curation"
    ],
    "license": "CECILL-2.1",
    "homepage": "https://gitlab.com/Daniel-KM/Omeka-S-module-DynamicItemSets",
    "authors": [
        {
            "name": "Daniel Berthereau",
            "email": "Daniel.packagist@Berthereau.net"
        }
    ],
    "support": {
        "issues": "https://gitlab.com/Daniel-KM/Omeka-S-module-DynamicItemSets/-/issues",
        "forum": "https://forum.omeka.org/"
    },
    "_require (not set until Omeka S merges PR #2412)": {
        "omeka/omeka-s": "^4.0",
        "daniel-km/omeka-s-module-common": "*"
    },
    "autoload": {
        "psr-4": {
            "DynamicItemSets\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DynamicItemSetsTest\\": "tests/DynamicItemSetsTest/"
        }
    },
    "extra": {
        "installer-name": "DynamicItemSets"
    }
}
